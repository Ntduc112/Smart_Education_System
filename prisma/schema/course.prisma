enum course_status {
    DRAFT
    PUBLISHED
}

model Category {
    id          String   @id @default(uuid())
    name        String
    description String
    created_at  DateTime @default(now())
    updated_at  DateTime @updatedAt
    courses     Course[]
}

model Course {
    id            String        @id @default(uuid())
    title         String
    description   String
    thumbnail     String
    price         Decimal
    level         String
    status        course_status
    created_at    DateTime      @default(now())
    updated_at    DateTime      @updatedAt
    instructor_id String
    instructor    User          @relation(fields: [instructor_id], references: [id])
    category_id   String
    category      Category      @relation(fields: [category_id], references: [id])
    sections      Chapter[]
    enrollments   Enrollment[]
    wishlist      Wishlist[]
    payments      Payment[]
    reviews       Review[]
    certificates  Certificate[]
}


model Chapter {
    id        String   @id @default(uuid())
    title     String
    course_id String
    order     Int
    course    Course   @relation(fields: [course_id], references: [id])
    lessons   Lesson[]
}

model Lesson {
    id             String           @id @default(uuid())
    title          String
    order          Int
    content        String?
    video_url      String?
    pdf_url        String?
    quiz           Quiz[]
    is_free        Boolean          @default(false)
    chapter_id     String
    chapter        Chapter          @relation(fields: [chapter_id], references: [id])
    lessonProgress LessonProgress[]
    questions      LessonQuestion[]
}

enum payment_status {
    PENDING
    PAID
    CANCELLED
    FAILED
}

model Review {
    id         String   @id @default(uuid())
    user_id    String
    user       User     @relation(fields: [user_id], references: [id])
    course_id  String
    course     Course   @relation(fields: [course_id], references: [id])
    rating     Int
    comment    String?
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@unique([user_id, course_id])
}

model Certificate {
    id             String   @id @default(uuid())
    user_id        String
    user           User     @relation(fields: [user_id], references: [id])
    course_id      String
    course         Course   @relation(fields: [course_id], references: [id])
    issued_at      DateTime @default(now())
    certificate_no String   @unique

    @@unique([user_id, course_id])
}

model Payment {
    id         String         @id @default(uuid())
    user_id    String
    user       User           @relation(fields: [user_id], references: [id])
    course_id  String
    course     Course         @relation(fields: [course_id], references: [id])
    amount     Decimal
    status     payment_status @default(PENDING)
    order_code Int            @unique
    created_at DateTime       @default(now())
    updated_at DateTime       @updatedAt
}
